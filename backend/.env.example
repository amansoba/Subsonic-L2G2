# --- Backend (Firebase Admin SDK) ---
# Path to your Firebase service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json

# Which DAO backend to use: "memory" (default) or "firestore"
SUBSONIC_DAO_BACKEND=memory

# Set to "true" to use fake auth (no real Firebase verification)
SUBSONIC_USE_FAKE_AUTH=true

# Demo token accepted by fake auth (optional)
SUBSONIC_DEMO_IDTOKEN=demo-token

# --- Frontend (Firebase JS SDK) ---
# These go in view/static/js/firebase-config.js
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
